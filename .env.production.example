# Environment variables for production deployment
# Add these to your Vercel project settings

# Server-side wallet private key (optional - only needed for server-side fallback)
# WARNING: Never expose this in client-side code
PRIVATE_KEY=

# App Kit key for server-side swap quote estimation
# Get this from Circle Console: https://console.circle.com/
APP_KIT_KEY=

# Public App Kit key for browser-based quote previews
# This can be safely exposed to the client
NEXT_PUBLIC_APP_KIT_KEY=
# Copy this file to .env.local and add your values

# Your EVM wallet private key for server-side bridge/transfer operations.
# This value is only required if you want the app to use a server-side wallet
# when no browser wallet is connected.
PRIVATE_KEY=

# Optional App Kit key for swap quotes, premium workflows, and quote estimation.
# Use either a browser-facing key or a server-side key depending on your deployment.
# For browser flows, expose a public key safely using NEXT_PUBLIC_APP_KIT_KEY.
NEXT_PUBLIC_APP_KIT_KEY=
APP_KIT_KEY=
